<UserControl x:Class="WorkoutMixer.Components.ChartSegmentsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:models="clr-namespace:WorkoutMixer.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Name="Root"
             mc:Ignorable="d">
    <Border Margin="4,0,0,0"
            Padding="6"
            Background="White"
            CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Margin="0,0,0,4">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Text="Chart segments" />
                    <TextBlock Foreground="#FF5E6875"
                               Text="Edit zone, minutes, seconds and RPM, then reorder as needed." />
                </StackPanel>

                <Button Width="108"
                        Height="26"
                        HorizontalAlignment="Right"
                        Command="{Binding AddChartDataPointCommand, ElementName=Root}"
                        DockPanel.Dock="Right">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconModern Width="11"
                                                  Height="11"
                                                  Margin="0,0,5,0"
                                                  VerticalAlignment="Center"
                                                  Kind="Add" />
                        <TextBlock VerticalAlignment="Center"
                                   Text="Add segment" />
                    </StackPanel>
                </Button>
            </DockPanel>

            <DataGrid x:Name="ChartDataPointsGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      IsReadOnly="False"
                      ItemsSource="{Binding ItemsSource, ElementName=Root}"
                      RowHeaderWidth="0"
                      RowHeight="32"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="*"
                                            Header="Zone">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            d:DataContext="{d:DesignInstance Type=models:ChartDataPoint, IsDesignTimeCreatable=False}">
                                    <Border Width="12"
                                            Height="12"
                                            Margin="0,0,6,0"
                                            Background="{Binding Zone.Brush}"
                                            BorderBrush="#33000000"
                                            BorderThickness="1"
                                            CornerRadius="2" />
                                    <TextBlock VerticalAlignment="Center"
                                               Text="{Binding Zone.Name}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox
                                    d:DataContext="{d:DesignInstance Type=models:ChartDataPoint, IsDesignTimeCreatable=False}"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{Binding AvailableZones, ElementName=Root}"
                                    SelectedItem="{Binding Zone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="100"
                                            Header="Minutes">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="{Binding DurationMinutes, StringFormat=0.##}"
                                           TextAlignment="Center"
                                           d:DataContext="{d:DesignInstance Type=models:ChartDataPoint, IsDesignTimeCreatable=False}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <mah:NumericUpDown
                                    d:DataContext="{d:DesignInstance Type=models:ChartDataPoint, IsDesignTimeCreatable=False}"
                                    Minimum="0.01"
                                    Interval="0.25"
                                    Speedup="False"
                                    StringFormat="0.##"
                                    Value="{Binding DurationMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="100"
                                            Header="Seconds">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="{Binding DurationSeconds, StringFormat=0}"
                                           TextAlignment="Center"
                                           d:DataContext="{d:DesignInstance Type=models:ChartDataPoint, IsDesignTimeCreatable=False}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <mah:NumericUpDown
                                    d:DataContext="{d:DesignInstance Type=models:ChartDataPoint, IsDesignTimeCreatable=False}"
                                    Minimum="1"
                                    Interval="1"
                                    Speedup="False"
                                    StringFormat="0"
                                    Value="{Binding DurationSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="100"
                                            Header="RPM">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="{Binding Rpm}"
                                           TextAlignment="Center"
                                           d:DataContext="{d:DesignInstance Type=models:ChartDataPoint, IsDesignTimeCreatable=False}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <mah:NumericUpDown
                                    d:DataContext="{d:DesignInstance Type=models:ChartDataPoint, IsDesignTimeCreatable=False}"
                                    Minimum="1"
                                    Interval="1"
                                    Speedup="False"
                                    StringFormat="0"
                                    Value="{Binding Rpm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="100"
                                            Header="Actions">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            d:DataContext="{d:DesignInstance Type=models:ChartDataPoint, IsDesignTimeCreatable=False}">
                                    <Button Width="24"
                                            Height="22"
                                            Margin="0,0,2,0"
                                            Command="{Binding MoveChartDataPointUpCommand, ElementName=Root}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Move up">
                                        <iconPacks:PackIconModern Width="12"
                                                                  Height="12"
                                                                  Kind="ArrowUp" />
                                    </Button>
                                    <Button Width="24"
                                            Height="22"
                                            Margin="0,0,2,0"
                                            Command="{Binding MoveChartDataPointDownCommand, ElementName=Root}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Move down">
                                        <iconPacks:PackIconModern Width="12"
                                                                  Height="12"
                                                                  Kind="ArrowDown" />
                                    </Button>
                                    <Button Width="24"
                                            Height="22"
                                            Command="{Binding RemoveChartDataPointCommand, ElementName=Root}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Remove segment">
                                        <iconPacks:PackIconModern Width="12"
                                                                  Height="12"
                                                                  Kind="Delete" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
