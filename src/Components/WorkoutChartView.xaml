<UserControl x:Class="WorkoutMixer.Components.WorkoutChartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <Border Margin="0,0,0,4"
            Padding="6"
            Background="White"
            CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Margin="0,0,0,2">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <Button Width="28"
                            Height="22"
                            Margin="0,0,3,0"
                            Click="ZoomOutChart_Click"
                            ToolTip="Zoom out">
                        <iconPacks:PackIconModern Width="12"
                                                  Height="12"
                                                  Kind="Minus" />
                    </Button>
                    <Button Width="52"
                            Height="22"
                            Margin="0,0,3,0"
                            Click="ResetChartZoom_Click"
                            ToolTip="Reset zoom">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <iconPacks:PackIconModern Width="11"
                                                      Height="11"
                                                      Margin="0,0,4,0"
                                                      VerticalAlignment="Center"
                                                      Kind="Refresh" />
                            <TextBlock x:Name="ChartZoomTextBlock"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="1x" />
                        </StackPanel>
                    </Button>
                    <Button Width="28"
                            Height="22"
                            Click="ZoomInChart_Click"
                            ToolTip="Zoom in">
                        <iconPacks:PackIconModern Width="12"
                                                  Height="12"
                                                  Kind="Add" />
                    </Button>
                </StackPanel>
                <TextBlock FontSize="17"
                           FontWeight="SemiBold"
                           Text="Workout chart" />
                <TextBlock Margin="10,3,0,0"
                           Foreground="#FF5E6875"
                           Text="Segments and music list redraw this view automatically." />
            </DockPanel>

            <ScrollViewer x:Name="ChartScrollViewer"
                          Grid.Row="1"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollBarVisibility="Auto"
                          CanContentScroll="True">
                <Canvas x:Name="ChartCanvas"
                        Background="White"
                        MouseLeftButtonDown="ChartCanvas_MouseLeftButtonDown"
                        Width="1200"
                        ToolTipService.BetweenShowDelay="0"
                        ToolTipService.InitialShowDelay="0"
                        ToolTipService.ShowDuration="60000" />
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
