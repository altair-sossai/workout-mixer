<UserControl x:Class="WorkoutMixer.Components.Mp3FilesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:WorkoutMixer.Behaviors"
             xmlns:components="clr-namespace:WorkoutMixer.Components"
             x:Name="Root">
    <Border Margin="0,0,4,0"
            Padding="8"
            Background="White"
            CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="MP3 Files" />
                <TextBlock Margin="0,1,0,6"
                           Foreground="#FF5E6875"
                           Text="{Binding SummaryText, ElementName=Root}" />
                <StackPanel Orientation="Horizontal">
                    <Button Width="108"
                            Height="26"
                            Margin="0,0,4,0"
                            HorizontalAlignment="Left"
                            Command="{Binding AddFilesCommand, ElementName=Root}"
                            Content="Add files" />
                    <Button Width="108"
                            Height="26"
                            Margin="0,0,4,0"
                            Command="{Binding SaveFinalMixCommand, ElementName=Root}"
                            Content="Save MP3" />
                    <Button Width="118"
                            Height="26"
                            Command="{Binding SaveIntensityReportCommand, ElementName=Root}"
                            Content="Save intensities" />
                </StackPanel>
            </StackPanel>

            <ListBox x:Name="FilesListBox"
                     Grid.Row="1"
                     Margin="0,6,0,0"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemsSource="{Binding FilesSource, ElementName=Root}"
                     ScrollViewer.CanContentScroll="False"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     behaviors:SmoothScrollBehavior.IsEnabled="True"
                     SelectionMode="Single">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,0,0,4" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <components:Mp3FileListItem File="{Binding}"
                                                    MoveDownCommand="{Binding MoveDownCommand, RelativeSource={RelativeSource AncestorType={x:Type components:Mp3FilesPanel}}}"
                                                    MoveUpCommand="{Binding MoveUpCommand, RelativeSource={RelativeSource AncestorType={x:Type components:Mp3FilesPanel}}}"
                                                    RemoveCommand="{Binding RemoveCommand, RelativeSource={RelativeSource AncestorType={x:Type components:Mp3FilesPanel}}}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</UserControl>