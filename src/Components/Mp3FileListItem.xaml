<UserControl x:Class="WorkoutMixer.Components.Mp3FileListItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             x:Name="Root">
    <Border Padding="3" Background="#FFF8FAFD" BorderBrush="#FFDDE5EE" BorderThickness="1" CornerRadius="7">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Width="24"
                    Height="24"
                    Margin="0,0,6,0"
                    Background="#FFE8F1FC"
                    CornerRadius="8">
                <iconPacks:PackIconModern Width="12"
                                          Height="12"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Foreground="#FF1F5FAE"
                                          Kind="Music" />
            </Border>

            <DockPanel Grid.Column="1"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       LastChildFill="True">
                <Border Padding="4,1"
                        Background="#FF1F6FEB"
                        CornerRadius="6"
                        DockPanel.Dock="Left">
                    <TextBlock FontSize="9"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="{Binding File.Position, ElementName=Root, StringFormat={}#{0}}" />
                </Border>
                <TextBlock Margin="6,0,8,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Text="{Binding File.FileName, ElementName=Root}"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding File.Path, ElementName=Root}" />
                <TextBlock VerticalAlignment="Center"
                           FontSize="10"
                           Foreground="#FF556273"
                           Text="{Binding File.DurationFormatted, ElementName=Root}" />
                <TextBlock Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="10"
                           Foreground="#FF556273"
                           Text="{Binding File.SizeFormatted, ElementName=Root}" />
            </DockPanel>

            <TextBlock x:Name="CurrentTimeTextBlock"
                       Grid.Column="2"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="#FF314152"
                       Text="00:00 /" />

            <Slider x:Name="SeekSlider"
                    Grid.Column="3"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    IsMoveToPointEnabled="True"
                    Maximum="1"
                    Minimum="0"
                    Opacity="0.96"
                    PreviewMouseLeftButtonUp="SeekSlider_PreviewMouseLeftButtonUp"
                    Thumb.DragCompleted="SeekSlider_DragCompleted"
                    Thumb.DragStarted="SeekSlider_DragStarted"
                    ValueChanged="SeekSlider_ValueChanged" />

            <StackPanel Grid.Column="4"
                        Margin="0,0,8,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button x:Name="PlayButton"
                        Width="24"
                        Height="22"
                        Click="PlayButton_Click"
                        ToolTip="Play">
                    <iconPacks:PackIconModern Width="12"
                                              Height="12"
                                              Kind="ControlPlay" />
                </Button>

                <Button x:Name="PauseButton"
                        Width="24"
                        Height="22"
                        Margin="2,0,0,0"
                        Click="PauseButton_Click"
                        ToolTip="Pause">
                    <iconPacks:PackIconModern Width="12"
                                              Height="12"
                                              Kind="ControlPause" />
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="5"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Width="24"
                        Height="22"
                        Margin="0,0,2,0"
                        Command="{Binding MoveUpCommand, ElementName=Root}"
                        CommandParameter="{Binding File, ElementName=Root}"
                        ToolTip="Move up">
                    <iconPacks:PackIconModern Width="11"
                                              Height="11"
                                              Kind="ArrowUp" />
                </Button>
                <Button Width="24"
                        Height="22"
                        Margin="0,0,2,0"
                        Command="{Binding MoveDownCommand, ElementName=Root}"
                        CommandParameter="{Binding File, ElementName=Root}"
                        ToolTip="Move down">
                    <iconPacks:PackIconModern Width="11"
                                              Height="11"
                                              Kind="ArrowDown" />
                </Button>
                <Button Width="24"
                        Height="22"
                        Command="{Binding RemoveCommand, ElementName=Root}"
                        CommandParameter="{Binding File, ElementName=Root}"
                        ToolTip="Remove file">
                    <iconPacks:PackIconModern Width="11"
                                              Height="11"
                                              Kind="Delete" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>